      <aliases enabled='yes' />
      <column caption='Pickup Point' datatype='spatial' name='[Calculation_1524749953367908352]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Pickup_Lat], [Pickup_Lon])' />
      </column>
      <column caption='Dropoff Point' datatype='spatial' name='[Calculation_1524749953368170497]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKEPOINT([Dropoff_Lat], [Dropoff_Lon])' />
      </column>
      <column caption='Delivery Route' datatype='spatial' name='[Calculation_1524749953368309762]' role='measure' type='nominal'>
        <calculation class='tableau' formula='MAKELINE([Calculation_1524749953367908352], [Calculation_1524749953368170497])' />
      </column>
      <column caption='cost_variance_huf' datatype='real' default-format='c&quot;HUF &quot;#,##0.00;-&quot;HUF &quot;#,##0.00' name='[Calculation_912190034865639424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[actual_cost_per_km] - [cohort_avg_cost_per_km]' />
      </column>
      <column caption='On-Time %' datatype='real' default-format='p0.0%' name='[Calculation_912190034867294209]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [operational_status] = &apos;On Time&apos; THEN [order_id] END) / COUNT([order_id])' />
      </column>
      <column caption='SLA Breach %' datatype='real' name='[Calculation_999517646395973632]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.08' />
      </column>
      <column caption='The Remainder' datatype='real' name='[Calculation_999517646396063745]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - [Calculation_999517646395973632]' />
      </column>
      <column caption='The Bottom Half' datatype='integer' name='[Calculation_999517646397497346]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='The Metric (High Bleed %)' datatype='real' name='[Calculation_999517646401552391]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.045' />
      </column>
      <column caption='The Remainder (Bleed)' datatype='real' name='[Calculation_999517646401720328]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - [Calculation_999517646401552391]' />
      </column>
